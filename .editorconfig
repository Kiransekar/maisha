# EditorConfig — consistent formatting across editors/IDEs. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

# Markdown: two trailing spaces are a hard line break, so don't trim them.
[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
